  <button class="btn" onclick="assistantPrompt('Book Slot Help')">Book Slot Help</button>
  <button class="btn" onclick="assistantPrompt('OTP Help')">OTP Help</button>
  <textarea id="assistantOutput" readonly></textarea>
</div>

<script>
let otpCode="";
let books=[];
let bookings=[];

// Demo dataset generator
function loadDataset(){
  for(let i=1;i<=50;i++){ // simulate 5000 with 50 for demo
    books.push({
      title:"Book "+i,
      author:"Author "+i,
      year:2000+i,
      isbn:"ISBN"+i,
      category:i%2==0?"Programming":"History",
      rating:Math.round(Math.random()*5),
      description:"Description of book "+i,
      cover:"https://via.placeholder.com/80x120",
      popularity:Math.random(),
      status:i%3==0?"Available":(i%3==1?"Waitlist":"Unavailable"),
      copies:i%3==0?5:0
    });
  }
  document.getElementById("totalBooks").innerText=books.length;
  document.getElementById("availableBooks").innerText=books.filter(b=>b.status==="Available").length;
  searchBooks();
}

function generateOTP(){
  otpCode=Math.floor(100000+Math.random()*900000).toString();
  document.getElementById("otpSection").classList.remove("hidden");
  alert("Your OTP is: "+otpCode);
}

function verifyLogin(){
  let u=document.getElementById("username").value;
  let p=document.getElementById("password").value;
  let o=document.getElementById("otp").value;
  if(u==="librarian" && p==="bookbriefs123" && o===otpCode){
    document.getElementById("loginSection").classList.add("hidden");
    document.getElementById("librarySection").classList.remove("hidden");
    loadDataset();
  } else {
    document.getElementById("loginMsg").innerText="Invalid credentials or OTP.";
  }
}

function searchBooks(){
  let q=document.getElementById("searchBar").value.toLowerCase();
  let cat=document.getElementById("categoryFilter").value;
  let avail=document.getElementById("availabilityFilter").value;
  let results=books.filter(b=>{
    return (!cat||b.category===cat) && (!avail||b.status===avail) &&
      (b.title.toLowerCase().includes(q)||b.author.toLowerCase().includes(q)||b.isbn.toLowerCase().includes(q)||b.description.toLowerCase().includes(q));
  });
  document.getElementById("searchCount").innerText=results.length;
  document.getElementById("bookList").innerHTML="";
  results.forEach(b=>{
    let card=document.createElement("div");
    card.className="card book-card";
    card.innerHTML=`<img src="${b.cover}"><div class="book-info"><h3>${b.title}</h3><p>${b.author} (${b.year})</p><p>Status: ${b.status} (${b.copies} copies)</p><button class="btn" ${b.status!=="Available"?"disabled":""} onclick="bookSlot('${b.title}')">Book Slot</button></div>`;
    document.getElementById("bookList").appendChild(card);
  });
  document.getElementById("topScore").innerText=results.length?results[0].rating+results[0].popularity:"0";
}

function bookSlot(title){
  let name=prompt("Enter member name:");
  if(!name) return;
  let slot=new Date().toLocaleString();
  bookings.push({title:title,member:name,slot:slot});
  localStorage.setItem("bookings",JSON.stringify(bookings));
  renderBookings();
}

function renderBookings(){
  document.getElementById("yourBookings").innerHTML="";
  bookings.forEach(b=>{
    let div=document.createElement("div");
    div.textContent=`${b.member} booked ${b.title} at ${b.slot}`;
    document.getElementById("yourBookings").appendChild(div);
  });
  document.getElementById("totalBookings").innerText=bookings.length;
}

document.getElementById("aiAssistant").onclick=function(){
  document.getElementById("assistantPanel").style.display="flex";
};
